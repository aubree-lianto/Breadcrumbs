{
  "manifest_version": 3,
  "name": "Breadcrumbs Recorder",
  "version": "1.0",
  "description": "Captures DOM clicks for workflow recording",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1/*"],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src http://127.0.0.1:8000"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
